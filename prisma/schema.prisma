generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model application {
  id       String  @id @default(cuid())
  company  String
  link     String?
  status   String? @default("Saved")
  user_id  String
  role     String
  hr       String?
  metadata Json?
  users    users   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "application_user_id_foreign")
  notes    notes[]
}

model notes {
  id             String      @id @default(cuid())
  text           String
  application_id String
  application    application @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "notes_application_id_foreign")
}

model users {
  id          String        @id @default(cuid())
  user_name   String        @unique
  full_name   String
  email       String        @unique
  phone       String?       @unique
  password    String
  profile     String?
  experience  Int?          @default(0)
  bio         String?
  application application[]
}
